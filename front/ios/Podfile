require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
# Resolve react_native_pods.rb with node to allow for hoisting
ENV['RCT_NEW_ARCH_ENABLED'] = '0'
def node_require(script)
  # Resolve script with node to allow for hoisting
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

platform :ios, '16'
prepare_react_native_project!

# Setup permissions
setup_permissions([
  'Camera',
  'PhotoLibrary',
  'Notifications',
])

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'snaplink' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(require.resolve(\'expo-modules-autolinking\', { paths: [require.resolve(\'expo/package.json\')] }))(process.argv.slice(1))',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => :static
  $RNFirebaseAsStaticFramework = true
  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
  )

  pod 'RNFBAnalytics', :path => '../node_modules/@react-native-firebase/analytics'

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
        if config.name == 'Release'
          config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-O'
          config.build_settings['GCC_OPTIMIZATION_LEVEL'] = 's'
        else
          config.build_settings['SWIFT_OPTIMIZATION_LEVEL'] = '-Onone'
        end
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
      end

      # Xcode 26+: C++ Pod 모듈 검증 비활성화 (iosfwd, string 등 C++ 헤더 미발견 방지)
      if ['glog', 'DoubleConversion'].include?(target.name)
        target.build_configurations.each do |config|
          config.build_settings['DEFINES_MODULE'] = 'NO'
        end
      end
    end

    # Fix react-native-date-picker missing string header for Xcode 26+
    date_picker_files = [
      '../node_modules/react-native-date-picker/ios/RNDatePickerManager.mm',
      '../node_modules/react-native-date-picker/ios/RNDatePicker.mm'
    ]

    date_picker_files.each do |file_path|
      file = File.join(File.dirname(__FILE__), file_path)
      if File.exist?(file)
        contents = File.read(file)
        unless contents.include?('#include <string>')
          # Add #include <string> at the very top of the file
          new_contents = "#include <string>\n" + contents
          File.write(file, new_contents)
          puts "Fixed #{file_path} - added missing <string> header"
        end
      end
    end

    # Fix fmt consteval compilation error with Xcode 26+ Clang
    fmt_base = File.join(installer.sandbox.pod_dir('fmt'), 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base)
      content = File.read(fmt_base)
      patched = content.gsub(/^#\s*define FMT_USE_CONSTEVAL 1$/, '#define FMT_USE_CONSTEVAL 0')
      if patched != content
        File.chmod(0644, fmt_base)
        File.write(fmt_base, patched)
        puts "Patched fmt: FMT_USE_CONSTEVAL set to 0 (Xcode 26+ fix)"
      end
    end
  end
end
