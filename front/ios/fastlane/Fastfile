# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

require 'json'

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # App Store Connect API Key 인증 설정
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_P8_CONTENT"],
      is_key_content_base64: true
    )

    # Increment build number (use timestamp or CI build number in GitHub Actions)
    increment_build_number(
      xcodeproj: "snaplink.xcodeproj",
      build_number: latest_testflight_build_number(api_key: api_key) + 1
    )

    # Sync version number from package.json
    json_path = File.join(File.dirname(__FILE__), "../../package.json")
    package = JSON.parse(File.read(json_path))
    package_version = package["version"]
    
    increment_version_number(
      xcodeproj: "snaplink.xcodeproj",
      version_number: package_version
    )

    # Build the app
    build_app(
      workspace: "snaplink.xcworkspace",
      scheme: "snaplink",
      export_method: "app-store",
      output_directory: "../build/ios",
      export_options: {
        provisioningProfiles: {
          "com.revede.snaplink" => "match AppStore com.revede.snaplink"
        }
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Download certificates and provisioning profiles"
  lane :certificates do
    match(
      type: "appstore",
      readonly: true,
      app_identifier: "com.revede.snaplink"
    )
  end

  desc "Push a new release build to the App Store"
  lane :release do
    # Increment build number
    increment_build_number(
      xcodeproj: "snaplink.xcodeproj"
    )

    # Build the app
    build_app(
      workspace: "snaplink.xcworkspace",
      scheme: "snaplink",
      export_method: "app-store",
      output_directory: "../build/ios"
    )

    # Upload to App Store
    upload_to_app_store(
      skip_metadata: false,
      skip_screenshots: true,
      submit_for_review: false
    )
  end

  desc "Deploy update via Revopush"
  lane :codepush do |options|
    # Default to 'Staging' if no deployment name is provided
    deployment_name = options[:deployment] || "Staging"
    
    # Run revopush release-react command
    # Fastlane is run from ios/ usually, command needs to run where package.json is (../)
    sh("cd .. && npx @revopush/code-push-cli release-react snaplink ios -d #{deployment_name} --token #{ENV['REVOPUSH_ACCESS_KEY']}")
  end
end
